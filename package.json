{
  "name": "simplesim",
  "version": "1.0.0",
  "description": "Simple alternative to Simulationcraft intended for easy customization",
  "main": "SimpleSim.js",
  "scripts": {
    "electron": "electron dist/main/electron.js",
    "server": "node dist/server/server.js",
    "build": "webpack --config webpack.main.js && webpack --config webpack.renderer.js && webpack --config webpack.renderer.advanced.js && webpack --config webpack.server.js",
    "dev:electron": "concurrently \"webpack --config webpack.main.js --watch\" \"webpack --config webpack.renderer.js --watch\" \"webpack --config webpack.renderer.advanced.js --watch\" \"wait-on dist/main/electron.js && electron dist/main/electron.js\"",
    "dev:server": "concurrently \"webpack --config webpack.server.js --watch\" \"webpack --config webpack.renderer.js --watch\" \"webpack --config webpack.renderer.advanced.js --watch\" \"nodemon dist/server/server.js\""
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Mattilego/SimpleSim.git"
  },
  "keywords": [
    "worldofwarcraft",
    "simulationcraft",
    "simulator"
  ],
  "author": "Mattias Strandberg",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/Mattilego/SimpleSim/issues"
  },
  "homepage": "https://github.com/Mattilego/SimpleSim#readme",
  "dependencies": {
    "blockly": "^12.5.1",
    "electron": "^40.6.1",
    "webpack": "^5.105.3"
  },
  "devDependencies": {
    "@babel/core": "^7.23.6",
    "@babel/preset-env": "^7.23.6",
    "babel-loader": "^9.1.3",
    "concurrently": "^8.2.2",
    "copy-webpack-plugin": "^12.0.2",
    "css-loader": "^7.1.2",
    "html-webpack-plugin": "^5.6.0",
    "mini-css-extract-plugin": "^2.9.0",
    "nodemon": "^3.0.2",
    "style-loader": "^4.0.0",
    "wait-on": "^7.2.0",
    "webpack-cli": "^5.1.4",
    "webpack-merge": "^5.10.0"
  },
  "overrides": {
    "serialize-javascript": "^7.0.2",
    "braces": "^3.0.3",
    "ssri": "^8.0.1",
    "postcss": "^8.4.31"
  }
}
